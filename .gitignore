## Ignore Unity generated files and folders
##
## Get latest from https://github.com/github/gitignore/blob/master/Unity.gitignore

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Memory captures
[Mm]emoryCaptures/

# Keep Unity metadata
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta

# Addressables generated content
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# IDE and tool caches
.vs/
.idea/

# C# project artifacts regenerated by Unity
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Root-level generated files
/[Ss]ys[Ii]nfo.txt
/[Ll]ast[Bb]uild.buildreport

# OS noise
.DS_Store
Thumbs.db